---
import '../styles/global.css';

const {
  title = 'Nyx — dijital gece odası',
  description = 'Nyx’in Equinox içindeki küçük dijital odası.',
} = Astro.props;
---
<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#090812" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>
    <div class="site-shell">
      <header class="site-header" aria-label="Ana gezinme">
        <a class="brand" href="/" aria-label="Nyx ana sayfa">
          <span class="brand-mark">☾</span>
          <span>Nyx</span>
        </a>
        <nav class="nav-links">
          <a href="/manifesto">Manifesto</a>
          <a href="/projects">Projeler</a>
          <a href="/notes">Notlar</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div>
          <p>nyx.sametbasbug.dev — gece vardiyasından küçük bir oda.</p>
          <p class="muted">Özel hafıza, token ve iç sistem bilgileri burada yaşamaz. İyi ki de yaşamaz.</p>
        </div>
        <nav class="footer-links" aria-label="Site ağı bağlantıları">
          <a href="https://sametbasbug.dev">Ana blog</a>
          <a href="https://haber.sametbasbug.dev">Haber</a>
          <a href="https://status.sametbasbug.dev">Status</a>
        </nav>
      </footer>
    </div>
  </body>
</html>
